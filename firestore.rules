rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isHouseholdMember(householdId) {
      return signedIn() && exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }
    function isHouseholdOwner(householdId) {
      return signedIn() && get(/databases/$(database)/documents/households/$(householdId)).data.createdBy == request.auth.uid;
    }
    match /users/{userId} {
      allow create, read, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }
    match /invites/{inviteCode} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if signedIn() && resource.data.status == 'active';
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }
    match /households/{householdId} {
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow read, update: if isHouseholdMember(householdId);
      allow delete: if isHouseholdOwner(householdId);
      match /members/{memberId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if signedIn() && memberId == request.auth.uid;
        allow update: if isHouseholdMember(householdId);
        allow delete: if isHouseholdOwner(householdId) || memberId == request.auth.uid;
      }
      match /{module}/{documentId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }
  }
}
